          gerencia@innovasystemscenter.com
        </a>
      </p>

      <p class="text-gray-300 text-sm">Teléfono / WhatsApp:</p>
      <a href="https://wa.me/573233259454" target="_blank"
         class="flex items-center gap-2 font-bold mt-1 hover:text-[#F39C12] transition">
        <i data-lucide="phone" class="w-5 h-5 text-[#F39C12]"></i>
        <i data-lucide="message-circle" class="w-5 h-5 text-[#25D366]"></i>
        <span>+57 323 325 9454</span>
      </a>

      <!-- Redes -->
      <div class="flex gap-4 mt-5">
