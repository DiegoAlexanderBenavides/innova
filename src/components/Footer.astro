      <ul class="space-y-2 text-gray-300 text-sm">
        <li><a href="/nosotros" class="hover:text-[#F39C12] transition">Sobre Nosotros</a></li>
        <li><a href="/contacto#formulario-contacto" class="hover:text-[#F39C12] transition">Contacto</a></li>
      </ul>
    </nav>

    <!-- CONTACTO -->
    <div>
      <h3 class="text-lg font-semibold text-[#F39C12] mb-4">Contacto</h3>

      <p class="text-gray-300 text-sm">Correo:</p>
      <p class="font-bold text-white mb-3">
