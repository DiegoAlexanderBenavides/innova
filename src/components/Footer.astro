<footer class="w-full bg-[#0A0A0A] text-white pt-10 pb-5 border-t border-[#1A1A1A]">

  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-4">

    <!-- LOGO + DESCRIPCIÓN -->
    <div>
      <a href="/" class="inline-block">
        <img src="/assets/images/logos_unidos.png" alt="Innova Systems Center" class="h-[58px] mb-4">
      </a>
      <p class="text-gray-400 text-sm leading-relaxed">
        Soluciones tecnológicas en <strong>desarrollo web, automatización, datos y contenido digital</strong> 
        para impulsar el crecimiento de empresas modernas en Colombia y Latinoamérica.
      </p>
    </div>

    <!-- SERVICIOS -->
    <nav>
      <h3 class="text-lg font-semibold text-[#F39C12] mb-4">Servicios</h3>
      <ul class="space-y-2 text-gray-300 text-sm">
        <li><a href="/recoleccion-y-analisis-de-datos" class="hover:text-[#F39C12] transition">Recolección y Análisis de Datos</a></li>
        <li><a href="/desarrollo-web-a-medida" class="hover:text-[#F39C12] transition">Desarrollo Web a Medida</a></li>
