---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Background from '../components/Background.astro';
import ModalViewImg from '../components/ModalViewImg.astro';
import { category, services } from '../data/siteData.ts';

const pageTitle = "Nuestros Servicios | INNOVA SYSTEMS CENTER - Soluciones Tecnológicas para tu Negocio";
const pageDescription = "Descubre los servicios de INNOVA SYSTEMS CENTER: desarrollo web, inteligencia artificial, bases de datos, ciberseguridad, cloud computing y más. ¡Impulsa tu negocio con tecnología innovadora!";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title={pageTitle} description={pageDescription}>
  <Background />
  <Header />
  <ModalViewImg />

  <main class="min-h-screen flex flex-col items-center justify-center text-center pt-30">
    <section class="bg-gradient-to-b from-[#111] to-[#222] text-white py-16 px-6 w-full">
      <h1 class="text-5xl font-extrabold text-[#F39C12] text-center mb-12 uppercase tracking-wide">
        Nuestros Servicios
      </h1>
      <p class="text-[#FFF] text-lg max-w-4xl mx-auto">En <strong class="text-[#F39C12]">Innova Systems Center</strong>, ofrecemos soluciones tecnológicas adaptadas a las necesidades de cada empresa. Nuestra experiencia nos permite desarrollar herramientas efectivas que optimizan operaciones, automatizan procesos y mejoran la gestión de datos.</p> <br>

      <!-- Filtros de Categoría -->
      <div class="text-center mb-12">
        <p class="text-gray-400 text-lg">Filtra por categoría:</p>
        <div class="flex flex-wrap justify-center gap-4 mt-4">
          <button onclick="filterProjects('all')" class="bg-[#F39C12] font-bold text-dark-900 text-lg px-6 py-3 rounded-md hover:bg-[#FEB94CFA] text-black transition">Todos</button>
          {Object.entries(category).map(([key, name]) => (
            <button onclick={`filterProjects('${key}')`} class="border border-[#F39C12] text-[#F39C12] font-bold text-lg px-6 py-3 rounded-md hover:bg-[#F39C12]/10 transition">{name.title}</button>
          ))}
        </div>
      </div>

      <!-- Sección de Servicios -->
      <div class="max-w-6xl mx-auto space-y-16">
        {services.map((service) => (
          <div id={service.id} class={`project-card ${service.category} transition duration-500`} data-animation="animate-fade-in-left">
            <div class="grid md:grid-cols-2 gap-8 items-center text-left">
              <div>
                <h2 class="text-4xl font-bold text-[#F39C12] mb-4">{service.title}</h2>
                <p class="text-[#FFF] text-lg mb-4 text-left" set:html={service.description}></p>
                <p class="text-[#FFF] text-lg mb-4 text-left" set:html={service.aditional}></p>
                <ul class="ml-4 list-disc text-[#FFF] pl-6 space-y-2 text-lg text-left">
                  {service.items.map((item) => (
                    <li set:html={item}></li>
                  ))}
                </ul>
                <div class="flex flex-wrap items-center gap-3 ml-4 mt-4">
                  <span class="font-semibold text-white whitespace-nowrap">Tecnologías:</span>
                  {service.technologies.map((tecnology) => (
                    tecnology.icono ? (
                      <img src={tecnology.icono} class="w-8 h-8 tech-icon" alt={tecnology.name} />
                    ) : (
                      <span class="text-gray-400">{tecnology.name}</span>
                    )
                  ))}
                </div>
              </div>
              <!-- Mini carrusel automático de imágenes -->
              <div class="relative w-full overflow-hidden rounded-xl" data-service-carousel>
                <div class="flex transition-transform duration-700 ease-in-out" data-carousel-track>
                  {service.images.map((image) => (
                    <div class="min-w-full">
                      <img
                        src={image.image}
                        alt={image.alt}
                        class="gallery-img cursor-pointer w-full h-64 object-cover rounded-xl shadow-lg"
                        onclick={`openModal('${image.image}')`}
                      />
                    </div>
                  ))}
                </div>
                <!-- Indicadores de puntos -->
                <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2" data-carousel-dots>
                  {service.images.map((_, i) => (
                    <button
                      class={`w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-[#F39C12] w-4' : 'bg-white/50'}`}
                      data-dot={i}
                      aria-label={`Imagen ${i + 1}`}
                    />
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA de Contacto -->
      <div class="mt-15 py-12 text-center">
        <p class="text-gray-400 text-lg mb-4">¿Quieres un proyecto similar? Contáctanos.</p>
        <a href={`${base}/nosotros#contact-form`} class="text-[#F39C12] font-bold text-xl hover:underline">
          Escríbenos aquí
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script src={`${base}/assets/js/services.js`} is:inline></script>
  <script src={`${base}/assets/js/modal_view_img.js`} is:inline></script>

  <script>
    function initServiceCarousels() {
      const carousels = document.querySelectorAll('[data-service-carousel]');

      carousels.forEach((carousel) => {
        const track = carousel.querySelector('[data-carousel-track]') as HTMLElement;
        const dots = carousel.querySelectorAll('[data-dot]');
        if (!track) return;

        const slides = track.children;
        const total = slides.length;
        let current = 0;
        let interval: ReturnType<typeof setInterval>;

        const goTo = (index: number) => {
          current = (index + total) % total;
          track.style.transform = `translateX(-${current * 100}%)`;
          dots.forEach((dot, i) => {
            const el = dot as HTMLElement;
            if (i === current) {
              el.classList.add('bg-[#F39C12]', 'w-4');
              el.classList.remove('bg-white/50', 'w-2');
            } else {
              el.classList.remove('bg-[#F39C12]', 'w-4');
              el.classList.add('bg-white/50', 'w-2');
            }
          });
        };

        const start = () => {
          clearInterval(interval);
          interval = setInterval(() => goTo(current + 1), 3000);
        };

        const stop = () => clearInterval(interval);

        // Pausar al pasar el cursor
        carousel.addEventListener('mouseenter', stop);
        carousel.addEventListener('mouseleave', start);

        // Clicks en los puntos
        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const i = parseInt((dot as HTMLElement).dataset.dot || '0');
            goTo(i);
          });
        });

        // Iniciar
        goTo(0);
        start();
      });
    }

    document.addEventListener('DOMContentLoaded', initServiceCarousels);
    document.addEventListener('astro:page-load', initServiceCarousels);
  </script>
</Layout>
