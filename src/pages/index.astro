---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Background from "../components/Background.astro";
import Contact from "../components/Contact.astro";
import { services } from "../data/siteData.ts";
import queSomosImg from "../assets/images/somos/que_somos.png";

const pageTitle =
	"INNOVA SYSTEMS CENTER | Desarrollo, Datos y Automatización para Empresas Modernas";
const pageDescription =
	"Ofrecemos soluciones tecnológicas en desarrollo web, automatización, análisis de datos y sistemas digitales que impulsan la eficiencia y crecimiento de tu empresa.";
const pageKeywords =
	"soluciones tecnológicas, transformación digital, desarrollo de software, desarrollo web, automatización...";
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
	<Background />
	<Header />

	<main
		class="min-h-screen flex flex-col items-center justify-center text-center bg-gradient-to-br from-[#050505] via-[#2A1604] to-[#050505] relative z-10"
	>
		<!-- HERO -->
		<section
			class="w-full min-h-screen opacity-0 flex flex-col justify-center pt-24 pb-12"
			data-animation="animate-fade-in"
		>
			<div
				class="max-w-7xl mx-auto px-6 w-full flex flex-col lg:flex-row items-center justify-between gap-12"
			>
				<!-- Text Column -->
				<div class="flex-1 text-left lg:pr-8">
					<p
						class="text-white text-4xl lg:text-5xl xl:text-6xl font-bold mb-6 leading-tight"
					>
						Soluciones <span class="text-[#F39C12]"
							>Tecnológicas</span
						> que Impulsan tu Negocio
					</p>

					<h1
						class="text-gray-300 text-lg lg:text-xl xl:text-2xl mb-8 font-light"
					>
						Desarrollo, Datos y Automatización para Empresas
						Modernas
					</h1>

					<div class="flex flex-col sm:flex-row gap-4 justify-start">
						<a
							href="#contact-form"
							class="bg-[#F39C12] font-bold px-8 py-3 rounded-md hover:bg-[#FEB94CFA] text-black text-center transition-all hover:scale-105"
						>
							Solicita tu Consultoría Gratuita
						</a>

						<a
							href="#nuestros_servicios"
							class="border border-[#F39C12] text-[#F39C12] font-semibold px-8 py-3 rounded-md hover:bg-[#F39C12]/10 transition-all text-center hover:scale-105"
						>
							Ver Servicios
						</a>
					</div>
				</div>

				<!-- Image Column -->
				<div
					class="flex-1 w-full mt-12 lg:mt-0 flex justify-center lg:justify-end"
				>
					<div class="relative w-full max-w-lg group">
						<div
							class="absolute -inset-1 bg-gradient-to-r from-[#F39C12] to-yellow-600 rounded-xl blur opacity-30 group-hover:opacity-50 transition duration-500"
						>
						</div>
						<img
							src={queSomosImg.src}
							alt="Qué Somos - Innova Systems Center"
							class="relative w-full h-auto rounded-xl shadow-2xl border border-[#2A2A2A] object-cover transition-transform duration-500 group-hover:scale-[1.02]"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- SERVICIOS -->
		<section
			id="nuestros_servicios"
			class="w-full bg-transparent py-24 relative z-10"
		>
			<div class="max-w-6xl mx-auto px-6 text-center">
				<p class="text-[#F39C12] font-semibold mb-3 tracking-wide">
					¿QUÉ HACEMOS?
				</p>

				<h2
					class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight"
				>
					Impulsamos tu crecimiento con
					<span class="text-[#F39C12]">soluciones digitales</span>
				</h2>

				<p class="text-lg text-gray-300 max-w-3xl mx-auto mb-14">
					Desarrollamos sistemas, automatizaciones y plataformas
					digitales diseñadas para optimizar procesos, potenciar
					decisiones estratégicas y acelerar la evolución tecnológica
					de tu organización.
				</p>

				<!-- CAROUSEL DE CARDS - marquee continuo -->
				<style>
					.marquee-wrapper {
						width: 100%;
						position: relative;
						overflow: hidden;
						padding: 1rem 0; /* espacio para que el scale no se corte */
						-webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
						mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
					}
					.marquee-track {
						display: flex;
						gap: 1.5rem;
						will-change: transform;
						align-items: stretch;
					}
					.marquee-card {
						flex-shrink: 0;
						width: 320px;
						transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
						position: relative;
						z-index: 1;
					}
					.marquee-card:hover {
						transform: scale(1.06);
						z-index: 20;
					}
					/* Fondo de la carta al hacer hover */
					.service-card-link {
						transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
					}
					.marquee-card:hover .service-card-link {
						background: linear-gradient(135deg, #F39C12 0%, #E67E22 100%);
						border-color: #F39C12;
						box-shadow: 0 0 40px rgba(243, 156, 18, 0.7);
					}
					/* Cambio de color en textos */
					.service-card-link .card-title {
						transition: color 0.3s ease;
					}
					.marquee-card:hover .card-title {
						color: #1a1a1a;
					}
					.service-card-link .card-items {
						transition: color 0.3s ease;
					}
					.marquee-card:hover .card-items {
						color: #2d2d2d;
					}
					.marquee-card:hover .card-items strong {
						color: #1a1a1a;
					}
					.service-card-link .card-dot {
						transition: background 0.3s ease;
					}
					.marquee-card:hover .card-dot {
						background-color: #1a1a1a;
					}
					.service-card-link .card-footer-text {
						transition: color 0.3s ease;
					}
					.marquee-card:hover .card-footer-text {
						color: #1a1a1a;
					}
					.service-card-link .card-footer-border {
						transition: border-color 0.3s ease;
					}
					.marquee-card:hover .card-footer-border {
						border-color: rgba(0,0,0,0.2);
					}
					@media (max-width: 640px) {
						.marquee-card { width: 85vw; }
					}
				</style>

				<div class="marquee-wrapper" id="marquee-wrapper">
					<div class="marquee-track" id="services-marquee">
						{
							/* Duplicamos las tarjetas para el loop infinito */
							[...services, ...services].map((service, idx) => (
								<div class="marquee-card">
									<a
										href={`/${service.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}
										class="service-card-link w-full h-full bg-[#1A1A1A] backdrop-blur rounded-xl border-2 border-[#F39C12]/40 shadow-[0_0_12px_rgba(243,156,18,0.15)] flex flex-col justify-between block"
									>
										<div>
											<div class="w-full flex justify-center p-3">
												<img
													src={service.logo}
													alt="Imagen representativa"
													class="w-full h-48 rounded-lg object-cover border-2 border-[#F39C12]/60"
												/>
											</div>
											<div class="p-5">
												<h3 class="card-title text-lg font-bold text-white mb-3">
													{service.title.replace(/[^\w\s\u00C0-\u00FF]/g, "")}
												</h3>
												<ul class="card-items text-gray-300 space-y-2 text-sm">
													{service.items.slice(0, 3).map((item) => (
														<li class="flex items-start gap-2">
															<span class="card-dot w-2 h-2 rounded-full bg-[#F39C12] mt-1.5 shrink-0" />
															<span set:html={item} />
														</li>
													))}
												</ul>
											</div>
										</div>
										<div class="card-footer-border p-5 pt-3 border-t border-[#F39C12]/20">
											<span class="card-footer-text text-[#F39C12] font-semibold flex items-center gap-1 text-sm">
												Ver servicio
												<span class="transition-transform group-hover/card:translate-x-1">→</span>
											</span>
										</div>
									</a>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<script>
			let marqueeRaf: number;
			let marqueePaused = false;

			function initMarquee() {
				const track = document.getElementById("services-marquee") as HTMLElement;
				const wrapper = document.getElementById("marquee-wrapper") as HTMLElement;
				if (!track || !wrapper) return;

				// Cancelar animación previa si existe
				if (marqueeRaf) cancelAnimationFrame(marqueeRaf);

				let offset = 0;
				const speed = 0.5; // píxeles por frame (~30px/s a 60fps)

				// Mitad del track = un set completo de tarjetas
				const getHalfWidth = () => track.scrollWidth / 2;

				function animate() {
					if (!marqueePaused) {
						offset += speed;
						// Cuando desplazamos un set completo, reseteamos al inicio (loop infinito)
						if (offset >= getHalfWidth()) {
							offset = 0;
						}
						track.style.transform = `translateX(-${offset}px)`;
					}
					marqueeRaf = requestAnimationFrame(animate);
				}

				// Pausar al pasar el cursor sobre el wrapper o cualquier tarjeta
				wrapper.addEventListener("mouseenter", () => { marqueePaused = true; });
				wrapper.addEventListener("mouseleave", () => { marqueePaused = false; });
				wrapper.addEventListener("touchstart", () => { marqueePaused = true; }, { passive: true });
				wrapper.addEventListener("touchend", () => { marqueePaused = false; }, { passive: true });

				marqueeRaf = requestAnimationFrame(animate);
			}

			document.addEventListener("DOMContentLoaded", initMarquee);
			document.addEventListener("astro:page-load", initMarquee);
			document.addEventListener("astro:before-swap", () => {
				if (marqueeRaf) cancelAnimationFrame(marqueeRaf);
			});
		</script>

		<!-- CONTACTO -->
		<section
			id="contact-form"
			class="w-full bg-transparent pt-10 pb-16 px-6 text-white text-left relative z-10"
		>
			<div class="max-w-4xl mx-auto">
				<h2 class="text-3xl font-bold text-[#F39C12] mb-4">
					¿Listo para impulsar tu transformación digital?
				</h2>
				<p class="text-gray-400 mb-6">
					Déjanos tu mensaje y te responderemos lo antes posible.
					Nuestro equipo está listo para ayudarte a mejorar tus
					procesos, automatizar sistemas y aprovechar tus datos de una
					forma más inteligente.
				</p>
				<Contact />
			</div>
		</section>
	</main>

	<Footer />
</Layout>
