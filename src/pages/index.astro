---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Background from "../components/Background.astro";
import Contact from "../components/Contact.astro";
import { services } from "../data/siteData.ts";
import queSomosImg from "../assets/images/somos/innova_principal.png";
import fondoEmprender from "../assets/images/empresas_aliadas/fondo_emprender.png";
import senaImg from "../assets/images/empresas_aliadas/sena.png";
import sectoresImg from "../assets/images/sectores_donde_trabajamos.png";
import principalImg from "../assets/images/principal3.png";

const pageTitle =
	"INNOVA SYSTEMS CENTER | Desarrollo, Datos y Automatización para Empresas Modernas";
const pageDescription =
	"Ofrecemos soluciones tecnológicas en desarrollo web, automatización, análisis de datos y sistemas digitales que impulsan la eficiencia y crecimiento de tu empresa.";
const pageKeywords =
	"soluciones tecnológicas, transformación digital, desarrollo de software, desarrollo web, automatización...";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
	<Background />
	<Header />

	<main
		class="min-h-screen flex flex-col items-center justify-center text-center bg-gradient-to-br from-[#050505] via-[#2A1604] to-[#050505] relative z-10"
	>
		<!-- HERO -->
		<section
			class="w-full min-h-screen opacity-0 flex flex-col justify-center pt-24 pb-12 relative"
			data-animation="animate-fade-in"
		>
			<!-- Fondo de imagen principal -->
			<div
				class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat opacity-20"
				style={`background-image: url('${principalImg.src}')`}
			>
			</div>

			<div
				class="max-w-7xl mx-auto px-6 w-full flex flex-col lg:flex-row items-center justify-between gap-12 relative z-10"
			>
				<!-- Text Column -->
				<div class="flex-1 text-left lg:pr-8">
					<p
						class="text-white text-4xl lg:text-5xl xl:text-6xl font-bold mb-6 leading-tight"
					>
						Soluciones <span class="text-[#F39C12]"
							>Tecnológicas</span
						> que Impulsan tu Negocio
					</p>

					<h1
						class="text-gray-300 text-lg lg:text-xl xl:text-2xl mb-8 font-light"
					>
						Desarrollo, Datos y Automatización para Empresas
						Modernas
					</h1>

					<div class="flex flex-col sm:flex-row gap-4 justify-start">
						<a
							href="#contact-form"
							class="bg-[#F39C12] font-bold px-8 py-3 rounded-md hover:bg-[#FEB94CFA] text-black text-center transition-all hover:scale-105"
						>
							Solicita tu Consultoría Gratuita
						</a>

						<a
							href="#nuestros_servicios"
							class="border border-[#F39C12] text-[#F39C12] font-semibold px-8 py-3 rounded-md hover:bg-[#F39C12]/10 transition-all text-center hover:scale-105"
						>
							Ver Servicios
						</a>
					</div>
				</div>

				<!-- Image Column -->
				<div
					class="flex-1 w-full mt-12 lg:mt-0 flex justify-center lg:justify-end"
				>
					<div class="relative w-full max-w-lg group">
						<img
							src={queSomosImg.src}
							alt="Qué Somos - Innova Systems Center"
							class="relative w-full h-auto object-cover transition-transform duration-500 group-hover:scale-[1.02]"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- EMPRESAS ALIADAS -->
		<section class="w-full overflow-hidden relative z-10 -my-16">
			<div class="max-w-4xl mx-auto px-6 text-center">
				<div
					class="flex flex-col sm:flex-row items-center justify-center gap-6 md:gap-16"
				>
					<img
						src={fondoEmprender.src}
						alt="Fondo Emprender"
						class="h-40 sm:h-52 lg:h-64 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity duration-300"
					/>
					<img
						src={senaImg.src}
						alt="SENA"
						class="h-40 sm:h-52 lg:h-64 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity duration-300"
					/>
				</div>
			</div>
		</section>

		<!-- SECTORES DONDE TRABAJAMOS -->
		<section class="w-full bg-[#0d0d0d] py-24 relative z-10">
			<div class="max-w-7xl mx-auto px-6">
				<!-- TEXTO centrado arriba -->
				<div class="text-center mb-12">
					<p class="text-[#F39C12] font-semibold tracking-wide mb-3">
						Sectores donde trabajamos
					</p>
					<h2
						class="text-4xl font-extrabold text-white leading-tight mb-5"
					>
						Soluciones adaptadas a cada tipo de organización.
					</h2>
					<p class="text-gray-300 text-lg max-w-3xl mx-auto">
						Transformamos tus datos en soluciones inteligentes según
						las necesidades de tu negocio.
					</p>
				</div>

				<!-- IMAGEN sectores -->
				<div class="flex justify-center">
					<img
						src={sectoresImg.src}
						alt="Sectores donde trabajamos"
						class="w-full max-w-2xl rounded-2xl shadow-xl border border-[#2a2a2a] object-cover"
					/>
				</div>
			</div>
		</section>

		<!-- SERVICIOS -->
		<section
			id="nuestros_servicios"
			class="w-full bg-transparent py-24 relative z-10"
		>
			<div class="max-w-6xl mx-auto px-6 text-center">
				<p class="text-[#F39C12] font-semibold mb-3 tracking-wide">
					¿QUÉ HACEMOS?
				</p>

				<h2
					class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight"
				>
					Impulsamos tu crecimiento con
					<span class="text-[#F39C12]">soluciones digitales</span>
				</h2>

				<p class="text-lg text-gray-300 max-w-3xl mx-auto mb-14">
					Desarrollamos sistemas, automatizaciones y plataformas
					digitales diseñadas para optimizar procesos, potenciar
					decisiones estratégicas y acelerar la evolución tecnológica
					de tu organización.
				</p>

				<!-- CAROUSEL DE CARDS - marquee continuo -->
				<style>
					.marquee-wrapper {
						overflow: hidden;
						width: 100%;
						position: relative;
						padding: 4rem 0; /* espacio para que el scale no se corte */
						/* desvanecimiento en los bordes */
						-webkit-mask-image: linear-gradient(
							to right,
							transparent 0%,
							black 8%,
							black 92%,
							transparent 100%
						);
						mask-image: linear-gradient(
							to right,
							transparent 0%,
							black 8%,
							black 92%,
							transparent 100%
						);
					}
					.marquee-track {
						display: flex;
						gap: 1.5rem;
						will-change: transform;
					}
					.marquee-card {
						flex-shrink: 0;
						width: 320px;
						position: relative;
						z-index: 1;
						transition: transform 0.3s ease;
					}
					.marquee-card:hover {
						transform: scale(1.06);
						z-index: 20;
					}
					.marquee-card a {
						transition:
							border-color 0.3s ease,
							border-width 0.3s ease,
							background-color 0.3s ease,
							box-shadow 0.3s ease;
					}
					.marquee-card:hover .card-link {
						border-color: #f39c12;
						border-width: 2px;
						border-radius: 6%;
						background: linear-gradient(
							160deg,
							#f39c12 0%,
							#1a0e00 55%,
							#0a0a0a 75%
						);
						box-shadow: 0 0 50px rgba(243, 156, 18, 0.55);
					}
					.marquee-card:hover .card-img {
						border-color: transparent;
					}
					@media (max-width: 640px) {
						.marquee-card {
							width: 85vw;
						}
					}
				</style>

				<div class="marquee-wrapper" id="marquee-wrapper">
					<div class="marquee-track" id="services-marquee">
						{
							/* Duplicamos las tarjetas para el loop infinito */
							[...services, ...services].map((service, idx) => (
								<div class="marquee-card">
									<a
										href={`${base}/${service.slug}`}
										class="card-link w-full h-full bg-[#1A1A1A] backdrop-blur rounded-xl border-2 border-[#F39C12]/40 shadow-[0_0_12px_rgba(243,156,18,0.15)] transition-all duration-300 flex flex-col justify-between block"
									>
										<div>
											<div class="w-full flex justify-center p-3">
												<img
													src={service.logo}
													alt="Imagen representativa"
													class="card-img w-full h-48 rounded-lg object-cover border-2 border-[#F39C12]/60 transition-all duration-300"
												/>
											</div>
											<div class="p-5">
												<h3 class="text-lg font-bold text-white mb-3">
													{service.title.replace(
														/[^\w\s\u00C0-\u00FF]/g,
														"",
													)}
												</h3>
												<ul class="text-gray-300 space-y-2 text-sm">
													{service.items
														.slice(0, 3)
														.map((item) => (
															<li class="flex items-start gap-2">
																<span class="w-2 h-2 rounded-full bg-[#F39C12] mt-1.5 shrink-0" />
																<span
																	set:html={
																		item
																	}
																/>
															</li>
														))}
												</ul>
											</div>
										</div>
										<div class="p-5 pt-3 border-t border-[#F39C12]/20">
											<span class="text-[#F39C12] font-semibold flex items-center gap-1 group-hover/card:underline text-sm">
												Ver servicio
												<span class="transition-transform group-hover/card:translate-x-1">
													→
												</span>
											</span>
										</div>
									</a>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<script>
			let marqueeRaf: number;
			let marqueePaused = false;

			function initMarquee() {
				const track = document.getElementById(
					"services-marquee",
				) as HTMLElement;
				const wrapper = document.getElementById(
					"marquee-wrapper",
				) as HTMLElement;
				if (!track || !wrapper) return;

				// Cancelar animación previa si existe
				if (marqueeRaf) cancelAnimationFrame(marqueeRaf);

				let offset = 0;
				const speed = 0.5; // píxeles por frame (~30px/s a 60fps)

				// Mitad del track = un set completo de tarjetas
				const getHalfWidth = () => track.scrollWidth / 2;

				function animate() {
					if (!marqueePaused) {
						offset += speed;
						// Cuando desplazamos un set completo, reseteamos al inicio (loop infinito)
						if (offset >= getHalfWidth()) {
							offset = 0;
						}
						track.style.transform = `translateX(-${offset}px)`;
					}
					marqueeRaf = requestAnimationFrame(animate);
				}

				// Pausar al pasar el cursor sobre el wrapper o cualquier tarjeta
				wrapper.addEventListener("mouseenter", () => {
					marqueePaused = true;
				});
				wrapper.addEventListener("mouseleave", () => {
					marqueePaused = false;
				});
				wrapper.addEventListener(
					"touchstart",
					() => {
						marqueePaused = true;
					},
					{ passive: true },
				);
				wrapper.addEventListener(
					"touchend",
					() => {
						marqueePaused = false;
					},
					{ passive: true },
				);

				marqueeRaf = requestAnimationFrame(animate);
			}

			document.addEventListener("DOMContentLoaded", initMarquee);
			document.addEventListener("astro:page-load", initMarquee);
			document.addEventListener("astro:before-swap", () => {
				if (marqueeRaf) cancelAnimationFrame(marqueeRaf);
			});
		</script>

		<!-- CONTACTO -->
		<section
			id="contact-form"
			class="w-full bg-transparent pt-10 pb-16 px-6 text-white text-left relative z-10"
		>
			<div class="max-w-4xl mx-auto">
				<h2 class="text-3xl font-bold text-[#F39C12] mb-4">
					¿Listo para impulsar tu transformación digital?
				</h2>
				<p class="text-gray-400 mb-6">
					Déjanos tu mensaje y te responderemos lo antes posible.
					Nuestro equipo está listo para ayudarte a mejorar tus
					procesos, automatizar sistemas y aprovechar tus datos de una
					forma más inteligente.
				</p>
				<Contact />
			</div>
		</section>
	</main>

	<Footer />
</Layout>
