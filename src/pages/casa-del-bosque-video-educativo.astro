---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Caso de Éxito – Casa del Bosque | Producción de Video Educativo Infantil | INNOVA SYSTEMS CENTER";
const pageDescription = "Descubre cómo INNOVA SYSTEMS CENTER creó un video educativo infantil para Casa del Bosque, combinando animación, narrativa y diseño audiovisual para generar aprendizaje dinámico y atractivo para niños.";
const pageKeywords = "caso de éxito, producción audiovisual, video educativo infantil, contenido infantil, animación para niños, storytelling infantil, edición de video, diseño audiovisual, producción digital, contenido educativo, Casa del Bosque, Fabrica Cuentos, Innova Systems Center, videos para educación, creatividad infantil, multimedia, diseño de contenido para niños, aprendizaje interactivo, producción de contenido educativo, video narrativo infantil, animación infantil Colombia";
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
  <Header />

  <main class="w-full">

    <!-- HERO -->
    <section class="w-full h-screen flex flex-col justify-center bg-center bg-cover bg-fixed"
      style="background-image: url('/assets/images/fondohome.png'); background-size: cover; background-position: center;"
      data-animation="animate-fade-in">

      <div class="w-full max-w-[1480px] px-6 mx-auto text-left mt-20">
        
        <!-- TÍTULO HERO -->
        <p class="text-white text-3xl lg:text-6xl font-bold max-w-3xl mb-6">
          Contenido Audiovisual que Educa y Conecta con los Niños
        </p>

        <!-- DESCRIPCIÓN -->
        <h1 class="text-white text-xl lg:text-2xl font-normal max-w-3xl mb-8 leading-relaxed">
          Edición y producción de un video educativo infantil para Casa del Bosque y Fábrica Cuentos,
          diseñado para fomentar el aprendizaje a través de narrativa visual, animación y contenido interactivo.
        </h1>

        <!-- BOTÓN -->
        <a href="/contacto#formulario-contacto"
          class="inline-block bg-[#F39C12] font-bold text-dark-900 text-lg px-6 py-3 rounded-md hover:bg-[#FEB94CFA] transition text-black">
          Quiero un resultado similar
        </a>
      </div>

    </section>

    <!-- IMPACTO GENERADO -->
    <section class="w-full py-20 bg-[#151515]">
      <div class="max-w-[1200px] mx-auto px-6 text-left">

        <h2 class="text-3xl font-bold text-white mb-10">Impacto generado</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

          <div class="bg-[#0D0D0D] p-6 rounded-lg border border-[#1A1A1A]">
            <i data-lucide="sparkles" class="w-10 h-10 text-[#F39C12] mb-4"></i>
            <p class="text-white font-bold text-3xl mb-2">+90%</p>
            <p class="text-gray-400 text-sm">Mejora en retención de la atención infantil.</p>
          </div>

          <div class="bg-[#0D0D0D] p-6 rounded-lg border border-[#1A1A1A]">
            <i data-lucide="film" class="w-10 h-10 text-[#F39C12] mb-4"></i>
            <p class="text-white font-bold text-3xl mb-2">Contenido dinámico</p>
            <p class="text-gray-400 text-sm">Video atractivo con narrativa visual optimizada.</p>
          </div>

          <div class="bg-[#0D0D0D] p-6 rounded-lg border border-[#1A1A1A]">
            <i data-lucide="book-open" class="w-10 h-10 text-[#F39C12] mb-4"></i>
            <p class="text-white font-bold text-3xl mb-2">Aprendizaje activo</p>
            <p class="text-gray-400 text-sm">Estructura audiovisual pensada para niños.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- LA EMPRESA -->
    <section class="w-full py-24 bg-[#0A0A0A]">
      <div class="max-w-[1300px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-14 text-left">

        <div>
          <p class="text-[#F39C12] text-sm font-semibold mb-2">LA ORGANIZACIÓN</p>
          <h2 class="text-4xl font-bold text-white leading-tight">
            Casa del Bosque y Fábrica Cuentos: contenido creativo para el aprendizaje infantil
          </h2>
        </div>

        <div>
          <p class="text-gray-300 text-lg mb-4">
            Casa del Bosque y Fábrica Cuentos producen contenidos educativos diseñados especialmente 
            para niños, con el objetivo de estimular la imaginación, el aprendizaje temprano y la exploración creativa.
          </p>

          <p class="text-gray-300 text-lg">
            Su misión es transformar conceptos educativos en experiencias audiovisuales dinámicas y accesibles.
            En este proyecto, necesitaban una pieza visual que fuese clara, atractiva y adaptada a la comprensión infantil.
          </p>
        </div>

      </div>
    </section>

    <!-- EL DESAFÍO -->
    <section class="w-full py-24 bg-[#0A0A0A] border-t border-[#1A1A1A]">
      <div class="max-w-[1300px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-14 text-left">

        <div>
          <p class="text-[#F39C12] text-sm font-semibold mb-2">EL DESAFÍO</p>
          <h2 class="text-4xl font-bold text-white leading-tight">
            Crear un video educativo atractivo, comprensible y adaptado a niños
          </h2>
        </div>

        <div>
          <p class="text-gray-300 text-lg mb-4">
            El reto consistía en convertir un contenido narrativo infantil en un video que transmitiera 
            mensajes educativos claros sin perder dinamismo, diversión y atención visual.
          </p>

          <p class="text-gray-300 text-lg">
            Se requería una edición profesional que integrara animaciones, transiciones suaves, 
            colores amigables y elementos visuales que mantuvieran el interés de los niños durante toda la historia.
          </p>
        </div>

      </div>
    </section>

    <!-- LA SOLUCIÓN -->
    <section class="w-full py-24 bg-[#0A0A0A] border-t border-[#1A1A1A]">
      <div class="max-w-[1300px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-14 text-left">

        <div>
          <p class="text-[#F39C12] text-sm font-semibold mb-2">LA SOLUCIÓN</p>
          <h2 class="text-4xl font-bold text-white leading-tight">
            Edición audiovisual infantil con narrativa dinámica y animación
          </h2>
        </div>

        <div>
          <ul class="space-y-4 text-gray-300 text-lg">

            <li class="flex items-start gap-3">
              <i data-lucide="pen-tool" class="w-6 h-6 text-[#F39C12] mt-1"></i>
              Diseño visual adaptado a niños: colores cálidos, ilustraciones y ritmo narrativo atractivo.
            </li>

            <li class="flex items-start gap-3">
              <i data-lucide="film" class="w-6 h-6 text-[#F39C12] mt-1"></i>
              Edición profesional con transiciones suaves, efectos ligeros y animación infantil.
            </li>

            <li class="flex items-start gap-3">
              <i data-lucide="volume-2" class="w-6 h-6 text-[#F39C12] mt-1"></i>
              Integración de música y narración educativa para maximizar comprensión y estímulo.
            </li>

            <li class="flex items-start gap-3">
              <i data-lucide="sparkles" class="w-6 h-6 text-[#F39C12] mt-1"></i>
              Optimización final para plataformas digitales y proyecciones educativas.
            </li>

          </ul>
        </div>

      </div>
    </section>

    <!-- RESULTADOS VISUALES DEL PROYECTO -->
    <section class="w-full py-24 bg-[#0A0A0A] border-t border-[#1A1A1A]">
      <div class="max-w-[1300px] mx-auto px-6">

        <!-- TÍTULO -->
        <div class="text-center mb-14">
          <p class="text-[#F39C12] font-semibold tracking-wide mb-2">RESULTADOS DEL PROYECTO</p>
          <h2 class="text-4xl font-bold text-white leading-tight">
            Imágenes y contenido final entregado
          </h2>
          <p class="text-gray-400 max-w-2xl mx-auto mt-4">
            Una muestra visual del proceso creativo y del resultado final desarrollado para Casa del Bosque.
          </p>
        </div>

        <!-- GALERÍA -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

          <!-- ITEM IMAGEN 1 -->
          <div class="group relative rounded-xl overflow-hidden border border-[#1A1A1A]">
            <img src="/assets/images/projects/clientes11.webp"
              class="w-full h-64 object-cover group-hover:scale-105 transition duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-60 group-hover:opacity-40 transition"></div>
          </div>

          <!-- ITEM IMAGEN 2 -->
          <div class="group relative rounded-xl overflow-hidden border border-[#1A1A1A]">
            <img src="/assets/images/projects/clientes12.webp"
              class="w-full h-64 object-cover group-hover:scale-105 transition duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-60 group-hover:opacity-40 transition"></div>
          </div>

          <!-- ITEM IMAGEN 3 -->
          <div class="group relative rounded-xl overflow-hidden border border-[#1A1A1A]">
            <img src="/assets/images/projects/clientes12.webp"
              class="w-full h-64 object-cover group-hover:scale-105 transition duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-60 group-hover:opacity-40 transition"></div>
          </div>

        </div>

        <!-- VIDEO PRINCIPAL -->
        <div class="mt-16">
          <h3 class="text-2xl font-bold text-white mb-6 text-center">Video final del proyecto</h3>

          <div class="w-full rounded-xl overflow-hidden border border-[#1A1A1A] shadow-lg">
            <video class="w-full h-auto" controls poster="/assets/images/casa_bosque_poster.webp">
              <source src="/assets/videos/casa_bosque_video.mp4" type="video/mp4" />
              Tu navegador no soporta videos HTML5.
            </video>
          </div>
        </div>

      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="w-full bg-[#151515] py-24 text-center">
      <div class="max-w-[700px] mx-auto px-6">
        <h2 class="text-3xl font-bold text-white mb-4">
          ¿Quieres convertir tu proyecto en un caso de éxito?
        </h2>

        <p class="text-gray-300 mb-8">
          Hablemos sobre tu idea y construyamos contenido audiovisual que conecte con tu audiencia.
        </p>

        <a href="/contacto#formulario-contacto"
          class="bg-[#F39C12] text-black font-bold px-8 py-4 rounded-md hover:bg-[#FEB94CFA] transition duration-300">
          Agenda una Consultoría
        </a>
      </div>
    </section>

  </main>

  <Footer />

</Layout>
