---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Background from '../components/Background.astro';
import ModalViewImg from '../components/ModalViewImg.astro';
import { category, projects } from '../data/siteData.ts';

const pageTitle = "Nuestros Proyectos | INNOVA SYSTEMS CENTER - Innovación Tecnológica en Acción";
const pageDescription = "Explora los proyectos innovadores de INNOVA SYSTEMS CENTER. Desde desarrollo web e inteligencia artificial hasta soluciones en la nube y bases de datos. ¡Conoce nuestras soluciones tecnológicas!";
---

<Layout title={pageTitle} description={pageDescription}>
  <Background />
  <Header />
  <ModalViewImg />

  <main class="min-h-screen flex flex-col items-center justify-center text-center pt-30">
    <section class="bg-gradient-to-b from-[#111] to-[#222] text-white py-16 px-6 w-full">
      <h1 class="text-5xl font-extrabold text-[#F39C12] text-center mb-12 uppercase tracking-wide">
        Nuestros Proyectos
      </h1>
      <p class="text-[#FFF] text-lg max-w-4xl mx-auto">Cada proyecto es un reto y una oportunidad para crear soluciones eficientes. En <strong class="text-[#F39C12]">Innova Systems Center</strong>, hemos trabajado con diversas empresas y organizaciones, transformando procesos a través de la tecnología.</p><br>

      <!-- Filtros de Categoría -->
      <div class="text-center mb-12">
        <p class="text-gray-400 text-lg">Filtra por categoría:</p>
        <div class="flex flex-wrap justify-center gap-4 mt-4">
          <button onclick="filterProjects('all')" class="bg-[#F39C12] font-bold text-dark-900 text-lg px-6 py-3 rounded-md hover:bg-[#FEB94CFA] text-black transition">Todos</button>
          {Object.entries(category).map(([key, name]) => (
            <button onclick={`filterProjects('${key}')`} class="border border-[#F39C12] text-[#F39C12] font-bold text-lg px-6 py-3 rounded-md hover:bg-[#F39C12]/10 transition">{name.title}</button>
          ))}
        </div>
      </div>

      <div class="max-w-6xl mx-auto space-y-20">
        {projects.map((project) => (
          <div id={project.id} class={`project-card ${project.category} transition duration-500`} data-animation="animate-fade-in-left">
            <div class="grid md:grid-cols-2 gap-8 items-center text-left">
              <div>
                <h2 class="text-4xl font-bold text-[#F39C12] mb-4">{project.title}</h2>
                <p class="text-gray-300 text-lg mb-4">{project.description}</p>
                <div class="flex items-center gap-3 ml-4 mt-4">
                  <span class="font-semibold text-white">Cliente:</span>
                  {project.client.map((client) => (
                    <img src={client.image} alt={client.alt} class={`cursor-pointer ${client.class}`} onclick={`openModal('${client.image}')`} />
                  ))}
                </div>
              </div>
              <div class="grid grid-cols-2 gap-4">
                {project.images.map((image) => (
                  <img src={image.image} alt={image.alt} class="gallery-img cursor-pointer rounded-lg shadow-lg transition transform hover:scale-105 w-full h-auto object-cover" onclick={`openModal('${image.image}')`} />
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA de Contacto -->
      <div class="mt-15 py-12 text-center">
        <p class="text-gray-400 text-lg mb-4">¿Tienes dudas? Contáctanos para más información.</p>
        <a href="/nosotros#contact-form" class="text-[#F39C12] font-bold text-xl hover:underline">
          Escríbenos aquí
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script src="/assets/js/projects.js" is:inline></script>
  <script src="/assets/js/modal_view_img.js" is:inline></script>
</Layout>
