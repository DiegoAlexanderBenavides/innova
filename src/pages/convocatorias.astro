---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Ofertas de Empleo en Tecnología | INNOVA SYSTEMS CENTER – Únete a Nuestro Equipo";
const pageDescription = "Únete a INNOVA SYSTEMS CENTER y trabaja en proyectos de desarrollo web, automatización, datos, marketing digital y soluciones tecnológicas para empresas. Vacantes activas, cultura innovadora y crecimiento profesional constante.";
const pageKeywords = "empleos tecnología, trabajos desarrollo web, vacantes programadores, trabajos data analytics, empleo automatización, ofertas de trabajo TI, desarrolladores Colombia, empleo remoto tecnología, Innova Systems Center empleos, work tech Colombia, empleo frontend, empleo backend, empleo fullstack, empleo bases de datos, trabajo marketing digital, vacantes creativos, empleo diseño UI, empleo edición de video, empleo contenidos digitales, trabajo analista de datos, oportunidades profesionales tecnología";
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
  <Header />

  <main class="w-full">

    <!-- HERO -->
    <section class="w-full h-screen flex flex-col justify-center bg-center bg-cover bg-fixed"
      style="background-image: url('/assets/images/fondohome.png'); background-size: cover; background-position: center;"
      data-animation="animate-fade-in">

      <div class="w-full max-w-[1480px] px-6 mx-auto text-left mt-20">

        <!-- Texto corto -->
        <p class="text-[#F39C12] text-lg font-semibold mb-3">
          Oportunidades laborales en tecnología
        </p>

        <!-- Título -->
        <h1 class="text-white text-3xl lg:text-6xl font-bold max-w-3xl mb-6 leading-tight">
          Trabaja con nosotros y construye el futuro digital
        </h1>

        <!-- Descripción -->
        <p class="text-white text-xl lg:text-2xl font-normal max-w-2xl mb-8 opacity-90">
          Buscamos talento apasionado por la tecnología, los datos, el desarrollo y la innovación. Crece, aprende y crea impacto real.
        </p>

        <!-- Botón -->
        <a href="#vacantes"
          class="inline-block bg-[#F39C12] font-bold text-dark-900 text-lg px-8 py-3 rounded-md hover:bg-[#FEB94CFA] transition text-black">
          Ver Vacantes Disponibles
        </a>
      </div>

    </section>

    <!-- VACANTES -->
    <section id="vacantes" class="w-full py-24 bg-[#0A0A0A] text-left">
      <div class="max-w-[1200px] mx-auto px-6">

        <h2 class="text-4xl font-bold text-white text-center mb-4">Vacantes Disponibles</h2>
        <p class="text-gray-400 text-center max-w-3xl mx-auto mb-16">
          Estas son las oportunidades actualmente abiertas en Innova Systems Center. 
          Cada puesto está diseñado para trabajar con proyectos reales y con impacto.
        </p>

        <div class="space-y-10">

          <!-- VACANTE -->
          <article class="bg-[#0D0D0D] p-8 rounded-2xl border border-[#1A1A1A] hover:border-[#F39C12] transition duration-300">

            <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-10">

              <!-- Información principal -->
              <div class="space-y-5">

                <!-- Badge estado -->
                <span class="inline-block text-xs font-bold px-3 py-1 rounded-full bg-green-500/10 text-[#ed4950] border border-[#d7797b]">
                  Convocatoria cerrada
                </span>

                <!-- Título -->
                <h3 class="text-2xl font-bold text-white leading-tight mt-3">
                  Diseñador Gráfico Junior - 001
                  <span class="block text-base text-gray-400 font-normal mt-2">
                    Trabajo presencial – Mocoa, Putumayo
                  </span>
                </h3>

                <!-- Duración de la convocatoria -->
                <div class="space-y-2 mt-4">

                  <p class="text-xs uppercase tracking-wide text-gray-500">
                    Duración de la convocatoria
                  </p>

                  <div class="flex flex-wrap gap-4 text-sm text-gray-400">

                    <span class="flex items-center gap-2">
                      <i data-lucide="calendar-clock" class="w-4 h-4 text-[#F39C12]"></i>
                      Inicio:
                      <strong class="text-white">
                        05 de enero de 2026 · 8:00 a. m.
                      </strong>
                    </span>

                    <span class="flex items-center gap-2">
                      <i data-lucide="calendar-x" class="w-4 h-4 text-[#F39C12]"></i>
                      Cierre:
                      <strong class="text-white">
                        12 de enero de 2026 · 11:59 p. m.
                      </strong>
                    </span>

                  </div>

                </div>

                <!-- Ubicación, modalidad y salario -->
                <div class="flex flex-wrap items-center gap-4 text-gray-400 text-sm mt-4">

                  <span class="flex items-center gap-2">
                    <i data-lucide="map-pin" class="w-4 h-4 text-[#F39C12]"></i>
                    Mocoa, Putumayo
                  </span>

                  <span class="flex items-center gap-2">
                    <i data-lucide="users" class="w-4 h-4 text-[#F39C12]"></i>
                    Modalidad presencial
                  </span>

                  <span class="flex items-center gap-2">
                    <i data-lucide="badge-dollar-sign" class="w-4 h-4 text-[#F39C12]"></i>
                    Salario:
                    <strong class="text-white">
                      1 SMMLV + prestaciones sociales
                    </strong>
                  </span>

                </div>

                <!-- Descripción -->
                <p class="text-gray-300 text-sm leading-relaxed max-w-3xl mt-4">
                  Buscamos una persona creativa, proactiva y con ganas de aprender, que apoye la
                  creación de contenido digital para redes sociales, campañas publicitarias y
                  proyectos internos. Esta vacante está dirigida a perfiles junior, técnicos o
                  tecnólogos, que deseen fortalecer su experiencia en un entorno real de trabajo.
                </p>

                <!-- Habilidades -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4">

                  <div class="flex items-center gap-3 bg-[#1A1A1A] p-3 rounded-lg">
                    <i data-lucide="video" class="w-5 h-5 text-[#F39C12]"></i>
                    <span class="text-gray-300 text-sm">Edición básica de video</span>
                  </div>

                  <div class="flex items-center gap-3 bg-[#1A1A1A] p-3 rounded-lg">
                    <i data-lucide="image" class="w-5 h-5 text-[#F39C12]"></i>
                    <span class="text-gray-300 text-sm">Diseño y creación de piezas gráficas</span>
                  </div>

                  <div class="flex items-center gap-3 bg-[#1A1A1A] p-3 rounded-lg">
                    <i data-lucide="layout" class="w-5 h-5 text-[#F39C12]"></i>
                    <span class="text-gray-300 text-sm">Conocimientos básicos en herramientas digitales</span>
                  </div>

                  <div class="flex items-center gap-3 bg-[#1A1A1A] p-3 rounded-lg">
                    <i data-lucide="rocket" class="w-5 h-5 text-[#F39C12]"></i>
                    <span class="text-gray-300 text-sm">Actitud de aprendizaje y creatividad</span>
                  </div>

                </div>

                <!-- Link términos -->
                <div class="mt-4">
                  <a href="/docs/tdr-creativo-contenido.pdf"
                    target="_blank"
                    class="inline-flex items-center gap-2 text-sm text-[#F39C12] hover:underline">
                    <i data-lucide="file-text" class="w-4 h-4"></i>
                    Ver términos de referencia de la convocatoria
                  </a>
                </div>

              </div>

              <!-- Acción -->
              <div class="flex-shrink-0 self-center">
                <a href="/formulario-convocatoria-contenido-digital"
                  class="pointer-events-none bg-gray-400 text-gray-700 px-8 py-4 font-bold rounded-md
                        opacity-60 cursor-not-allowed select-none text-center block">
                  Postularme
                </a>

              </div>

            </div>

          </article>

        </div>

      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="w-full py-24 text-center bg-[#0A0A0A]">
      <div class="max-w-[700px] mx-auto px-6">

        <h2 class="text-3xl font-bold text-white mb-4">¿Quieres trabajar con nosotros?</h2>
        <p class="text-gray-300 mb-8">Envíanos tu hoja de vida y cuéntanos por qué quieres ser parte del equipo.</p>

        <a href="/contacto#formulario-contacto"
          class="inline-block bg-[#F39C12] px-8 py-4 text-lg font-bold text-black rounded-md hover:bg-[#FEB94CFA] transition">
          Contactar con Reclutamiento
        </a>

      </div>
    </section>

  </main>

  <Footer />

</Layout>
