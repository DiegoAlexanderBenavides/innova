---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Caso de Éxito: REDCICLAR | Plataforma de Gestión de Residuos con Inteligencia de Negocios – INNOVA SYSTEMS CENTER";
const pageDescription = "Descubre cómo desarrollamos REDCICLAR, un sistema web que optimiza la recolección de residuos en Cali mediante análisis en tiempo real, reducción de costos y planificación inteligente. Proyecto realizado para la Fundación CRESE.";
const pageKeywords = "sistema de gestión de residuos, plataforma de residuos, gestión de residuos, redciclar, caso de éxito redciclar, recolección de residuos Cali, sistema web de residuos, optimización ambiental, inteligencia de negocios, BI ambiental, dashboards residuos, sostenibilidad, gestión ambiental digital, plataforma de recolección de residuos, Fundación CRESE, transformación digital ambiental, monitoreo de residuos, trazabilidad residuos, automatización ambiental, análisis de datos ambientales, sistemas SIG, innovación sostenible, sistemas de gestión ambiental, software ambiental, desarrollo web ambiental, logística de residuos, planificación operativa residuos, logística de recolección, BI para residuos, trazabilidad de residuos, optimización operativa, integración de datos, indicadores ambientales, sistema Redciclar, planificación inteligente, monitoreo en tiempo real, sistema web ecológico, gestión operativa";
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
  <Header />

  <main class="w-full">

    <!-- HERO -->
    <section class="w-full h-screen flex flex-col justify-center bg-center bg-cover bg-fixed"
      style="background-image: url('/assets/images/fondohome.png'); background-size: cover; background-position: center;"
      data-animation="animate-fade-in">

      <div class="w-full max-w-[1480px] px-6 mx-auto text-left mt-20">
        
        <!-- TÍTULO HERO -->
        <p class="text-white text-3xl lg:text-6xl font-bold max-w-3xl mb-6">
          Tecnología que impulsa la sostenibilidad ambiental
        </p>

        <!-- DESCRIPCIÓN -->
        <h1 class="text-white text-xl lg:text-2xl font-normal max-w-3xl mb-8 leading-relaxed">
          Caso real donde desarrollamos REDCICLAR, un sistema web para optimizar la gestión de residuos en la ciudad de Cali, integrando análisis de datos, logística inteligente y reportes ambientales.
        </h1>

        <!-- BOTÓN -->
        <a href="/contacto#formulario-contacto"
          class="inline-block bg-[#F39C12] font-bold text-dark-900 text-lg px-6 py-3 rounded-md hover:bg-[#FEB94CFA] transition text-black">
          Quiero un resultado similar
        </a>
      </div>

    </section>

    <!-- IMPACTO GENERADO -->
    <section class="w-full py-20 bg-[#151515]">
      <div class="max-w-[1200px] mx-auto px-6 text-left">

        <h2 class="text-3xl font-bold text-white mb-10">Impacto generado</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

          <div class="bg-[#0D0D0D] p-6 rounded-lg border border-[#1A1A1A]">
            <i data-lucide="map" class="w-10 h-10 text-[#F39C12] mb-4"></i>
            <p class="text-white font-bold text-3xl mb-2">+40%</p>
            <p class="text-gray-400 text-sm">Mejora en la eficiencia de rutas de recolección.</p>
          </div>

          <div class="bg-[#0D0D0D] p-6 rounded-lg border border-[#1A1A1A]">
            <i data-lucide="factory" class="w-10 h-10 text-[#F39C12] mb-4"></i>
            <p class="text-white font-bold text-3xl mb-2">Costos ↓</p>
            <p class="text-gray-400 text-sm">Reducción de costos operativos mediante análisis inteligente.</p>
          </div>

          <div class="bg-[#0D0D0D] p-6 rounded-lg border border-[#1A1A1A]">
            <i data-lucide="leaf" class="w-10 h-10 text-[#F39C12] mb-4"></i>
            <p class="text-white font-bold text-3xl mb-2">Impacto verde</p>
            <p class="text-gray-400 text-sm">Monitoreo ambiental con métricas claras y trazables.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- LA EMPRESA -->
    <section class="w-full py-24 bg-[#0A0A0A]">
      <div class="max-w-[1300px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-14 text-left">

        <!-- Izquierda -->
        <div>
          <p class="text-[#F39C12] text-sm font-semibold mb-2">LA EMPRESA</p>
          <h2 class="text-4xl font-bold text-white leading-tight">
            Fundación CRESE: soluciones para el desarrollo social y ambiental
          </h2>
        </div>

        <!-- Derecha -->
        <div>
          <p class="text-gray-300 text-lg mb-4">
            La Fundación CRESE impulsa proyectos orientados al manejo responsable de residuos,
            sostenibilidad urbana y participación comunitaria. Para fortalecer estas iniciativas,
            necesitaban un sistema moderno que centralizara datos, optimizara rutas de recolección
            y analizara el impacto ambiental.
          </p>

          <p class="text-gray-300 text-lg">
            Antes de REDCICLAR, la información se registraba de forma manual,
            dificultando la planificación, generando sobrecostos y reduciendo la precisión
            en la evaluación del impacto ambiental.
          </p>
        </div>

      </div>
    </section>

    <!-- EL DESAFÍO -->
    <section class="w-full py-24 bg-[#0A0A0A] border-t border-[#1A1A1A]">
      <div class="max-w-[1300px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-14 text-left">

        <div>
          <p class="text-[#F39C12] text-sm font-semibold mb-2">EL DESAFÍO</p>
          <h2 class="text-4xl font-bold text-white leading-tight">
            Crear una plataforma integral para monitorear y optimizar la recolección de residuos
          </h2>
        </div>

        <div>
          <p class="text-gray-300 text-lg mb-4">
            CRESE necesitaba un sistema digital capaz de registrar recolecciones, cuantificar materiales,
            visualizarlos en mapas, generar reportes y entregar métricas ambientales en tiempo real.
          </p>

          <p class="text-gray-300 text-lg">
            El mayor reto era integrar logística, datos operativos y analítica ambiental
            en una sola plataforma accesible, intuitiva y segura.
          </p>
        </div>

      </div>
    </section>

    <!-- LA SOLUCIÓN -->
    <section class="w-full py-24 bg-[#0A0A0A] border-t border-[#1A1A1A]">
      <div class="max-w-[1300px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-14 text-left">

        <div>
          <p class="text-[#F39C12] text-sm font-semibold mb-2">LA SOLUCIÓN</p>
          <h2 class="text-4xl font-bold text-white leading-tight">
            Sistema web REDCICLAR con analítica ambiental integrada
          </h2>
        </div>

        <div>
          <ul class="space-y-4 text-gray-300 text-lg">

            <li class="flex items-start gap-3">
              <i data-lucide="globe" class="w-6 h-6 text-[#F39C12] mt-1"></i>
              Plataforma web para el registro y monitoreo de recolecciones por zonas.
            </li>

            <li class="flex items-start gap-3">
              <i data-lucide="route" class="w-6 h-6 text-[#F39C12] mt-1"></i>
              Optimización de rutas basadas en datos reales para aumentar eficiencia operativa.
            </li>

            <li class="flex items-start gap-3">
              <i data-lucide="bar-chart-3" class="w-6 h-6 text-[#F39C12] mt-1"></i>
              Dashboards ambientales para visualizar toneladas recicladas, zonas críticas y progreso mensual.
            </li>

            <li class="flex items-start gap-3">
              <i data-lucide="clipboard-list" class="w-6 h-6 text-[#F39C12] mt-1"></i>
              Reportes automáticos para entidades ambientales y administrativas.
            </li>

          </ul>
        </div>

      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="w-full bg-[#151515] py-24 text-center">
      <div class="max-w-[700px] mx-auto px-6">
        <h2 class="text-3xl font-bold text-white mb-4">
          ¿Quieres convertir tu proyecto en un caso de éxito?
        </h2>

        <p class="text-gray-300 mb-8">
          Conversemos sobre tus objetivos y construyamos la solución tecnológica
          que tu organización necesita.
        </p>

        <a href="/contacto#formulario-contacto"
          class="bg-[#F39C12] text-black font-bold px-8 py-4 rounded-md hover:bg-[#FEB94CFA] transition duration-300">
          Agenda una Consultoría
        </a>
      </div>
    </section>

  </main>

  <Footer />

</Layout>
